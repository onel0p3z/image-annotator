{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Extension Tests",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionTestsPath=${workspaceFolder}/dist/test/suite"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/test/**/*.js"
      ]
    }
  ]
}
