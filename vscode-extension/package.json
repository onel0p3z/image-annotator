{
  "name": "antigravity-annotator",
  "displayName": "Antigravity Annotator",
  "description": "Image annotation tool for AI context",
  "version": "1.0.0",
  "publisher": "your-name",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity.annotate",
        "title": "Annotate Image from Clipboard"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node ./dist/test/runTest.js --reporter-options spec=-"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/mocha": "^10.0.6",
    "@vscode/test-electron": "^2.3.9",
    "typescript": "^5.3.3",
    "glob": "^10.3.10"
  }
}
