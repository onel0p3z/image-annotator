{
  "name": "image-annotator",
  "displayName": "Image Annotator",
  "description": "Image annotation tool for AI context",
  "version": "1.0.0",
  "icon": "images/icon.png",
  "publisher": "onel0p3z",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/onel0p3z/image-annotator"
  },
  "keywords": [
    "ai",
    "gemini",
    "annotation",
    "image",
    "code-review"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:image-annotator.annotate"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "image-annotator.annotate",
        "title": "Annotate Image"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "image-annotator.annotate",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Image Annotator",
      "properties": {
        "image-annotator.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for Google Gemini (AI Analysis)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild ./srcs/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild ./srcs/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "package": "vsce package"
  },
  "dependencies": {
    "@google/genai": "^1.30.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.27.1"
  }
}
